{
    "name": "weborange/visual-builder",
    "description": "Framework-agnostic, build-step-free visual HTML ↔ JSON page-section builder for Laravel. Persistence and dynamic-token sources are provided by the host app via contracts.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "visual-builder", "page-builder", "html", "editor"],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0",
        "illuminate/http": "^10.0 || ^11.0 || ^12.0",
        "illuminate/routing": "^10.0 || ^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Weborange\\VisualBuilder\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Weborange\\VisualBuilder\\VisualBuilderServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
